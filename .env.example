# PostgreSQL connection string
DATABASE_URL=

# From Twitch developer console
TWITCH_CLIENT_ID=

# From Twitch developer console
TWITCH_CLIENT_SECRET=

# OAuth callback URL, e.g. http://localhost:3000/api/auth/twitch/callback
